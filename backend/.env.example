# ── Application ──────────────────────────────────────────────
APP_NAME=MedLinka
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=change-this-to-a-very-long-random-secret-key-in-production

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./medlinka.db

# ── JWT Settings ─────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI (Gemini) ──────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# ── Expo Push Notifications ──────────────────────────────────
EXPO_ACCESS_TOKEN=your-expo-access-token-here

# ── Supported Languages ──────────────────────────────────────
SUPPORTED_LANGUAGES=ar,tr,en
DEFAULT_LANGUAGE=ar

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,exp://localhost:8081
